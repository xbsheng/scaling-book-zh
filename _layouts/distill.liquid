<!doctype html>
<html>

<head>
  {% include head.liquid %}

  <!-- Distill js -->
  <script src="{{ '/assets/js/distillpub/template.v2.js' | relative_url }}"></script>
  <script src="{{ '/assets/js/distillpub/transforms.v2.js' | relative_url }}"></script>
  {% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {
        {
        page._styles
      }
    }
  </style>
  {% endif %}
</head>

<d-front-matter>
  <script async type="text/json">
      {
            "title": {{ page.title | jsonify }},
            "description": {{ page.description | jsonify }},
            "published": "{{ page.date | date: '%B %d, %Y' }}",
            "authors": [
              {% for author in page.authors %}
              {
                "author": "{{ author.name }}",
                "authorURL": "{{ author.url }}",
                "affiliations": [
                  {
                    "name": "{{ author.affiliations.name }}",
                    "url": "{{ author.affiliations.url }}"
                  }
                ]
              }{% if forloop.last == false %},{% endif %}
              {% endfor %}
            ],
            "katex": {
              "delimiters": [
                {
                  "left": "$",
                  "right": "$",
                  "display": false
                },
                {
                  "left": "$$",
                  "right": "$$",
                  "display": true
                }
              ]
            }
          }
    </script>
</d-front-matter>

<body
  class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
  <!-- Header -->
  {% include header.liquid %}

  <!-- Content -->
  <div class="post distill">

    <d-title>
      <h1>{{ page.title }}</h1>
      {% if page.subtitle %}
      <p><span class="subtitle">{{ page.subtitle }}</span> <span class="subtitle-links">({{ page.previous_section_name
          }} | <a href="{{ page.next_section_url }}">{{ page.next_section_name }}</a>)</span></p>
      {% else %}
      <p>Part {{ page.section_number }} of <a href="{{ site.baseurl }}">{{ site.title }}</a> (<a
          href="{{ page.previous_section_url }}">{{ page.previous_section_name }}</a> | <a
          href="{{ page.next_section_url }}">{{ page.next_section_name }}</a>)</p>
      {% endif %}
      <p>{{ page.description }}</p>
    </d-title>

    {% if page.authors %}
    <!-- Pre-render the byline server-side so it's visible at first paint. The distill JS
         re-renders it from <d-front-matter> on DOMContentLoaded, so the markup here must
         mirror bylineTemplate() in assets/js/distillpub/template.v2.js exactly. -->
    {% assign byline_half = page.authors.size | plus: 1 | divided_by: 2 %}
    <d-byline>
      <div class="byline grid">
        <div class="authors-affiliations grid">
          <h3 style="grid-column: 1; grid-row: 1;">Authors</h3>
          <h3></h3>
          <h3>Affiliation</h3>
          {% for author in page.authors %}
          {% assign byline_col = forloop.index0 | divided_by: byline_half | plus: 1 %}
          {% assign byline_row = forloop.index0 | modulo: byline_half | plus: 2 %}
          <p class="author" style="grid-column: {{ byline_col }}; grid-row: {{ byline_row }};">
            {% if author.url %}<a class="name" href="{{ author.url }}">{{ author.name }}</a>{% else %}<span class="name">{{ author.name }}</span>{% endif %}
          </p>
          <p class="affiliation" style="grid-column: 3; grid-row: {{ byline_row }};">
            {% if author.affiliations.url %}<a class="affiliation" href="{{ author.affiliations.url }}">{{ author.affiliations.name }}</a>{% else %}<span class="affiliation">{{ author.affiliations.name }}</span>{% endif %}
          </p>
          {% endfor %}
        </div>
        <div>
          <h3>Published</h3>
          <!-- Match the AP-style month abbreviations in template.v2.js's `months` array. -->
          {% assign byline_months = "Jan.,Feb.,March,April,May,June,July,Aug.,Sept.,Oct.,Nov.,Dec." | split: "," %}
          {% assign byline_month_idx = page.date | date: '%-m' | minus: 1 %}
          <p>{{ byline_months[byline_month_idx] }} {{ page.date | date: '%-d, %Y' }}</p>
        </div>
      </div>
    </d-byline>
    {% endif %}

    <d-article>
      {% if page.toc %}
      <d-contents>
        <nav class="l-text figcaption">
          <h3>Contents</h3>
          {% for section in page.toc %}
          <div>
            <a href="#{{ section.name | slugify }}">{{ section.name }}</a>
          </div>
          {% if section.subsections %}
          <ul>
            {% for subsection in section.subsections %}
            <li>
              <a href="#{{ subsection.name | slugify }}">{{ subsection.name }}</a>
            </li>
            {% endfor %}
          </ul>
          {% endif %}
          {% endfor %}
        </nav>
      </d-contents>
      {% endif %}
      {{ content }}
    </d-article>

    <d-appendix>
      <d-footnote-list></d-footnote-list>
      <d-citation-list></d-citation-list>
      {% include miscellaneous.liquid %}
      {% include distill-citation.liquid %}
    </d-appendix>

    <d-bibliography src="{{ page.bibliography | prepend: '/assets/bibliography/' | relative_url }}"></d-bibliography>

    {% if site.disqus_shortname and page.disqus_comments %}{% include disqus.liquid %}{% endif %}
    {% if site.giscus.repo and page.giscus_comments %}
    {% include giscus.liquid %}
    {% endif %}
  </div>

  <!-- Footer -->
  {% include footer.liquid %}

  <!-- JavaScripts -->
  {% include distill_scripts.liquid %}
</body>

</html>